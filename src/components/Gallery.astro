---
// =========================================================================
// Gallery.astro — responsive masonry-ish grid + accessible lightbox.
//  - lazy-loaded images; elegant gradient placeholder when a file 404s
//  - click/Enter opens a lightbox (focus-trapped, Esc + arrows to navigate)
//  - dispatches gallery_open (defensive analytics) on first open
//  - paths via withBase(); never hotlinks external media
// =========================================================================
import { getLocaleFromUrl, useTranslations, withBase } from '../i18n/utils';

interface Props {
  /** Relative /public image paths (from yachts.ts gallery[]). */
  images: string[];
  /** Yacht name for alt text + analytics. */
  name: string;
}

const { images, name } = Astro.props;
const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const tints = [
  'linear-gradient(135deg, #102e36, #18424c)',
  'linear-gradient(135deg, #0b2128, #102e36)',
  'linear-gradient(135deg, #18424c, #06141a)',
  'linear-gradient(135deg, #102e36, #0b2128)',
];
---

<section class="gallery">
  <header class="mb-8">
    <h2 class="overline">{t('yachtsCommon.galleryTitle')}</h2>
  </header>

  <ul
    class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4"
    data-gallery
    data-gallery-name={name}
  >
    {
      images.map((src, i) => (
        <li class={i % 5 === 0 ? 'sm:col-span-2 sm:row-span-2' : ''}>
          <button
            type="button"
            class="group relative block aspect-square w-full overflow-hidden rounded-md border border-line focus-visible:outline-none"
            data-gallery-item
            data-index={i}
            data-src={withBase(src)}
            aria-label={`${name} — ${i + 1}`}
          >
            <span
              class="absolute inset-0 transition-transform duration-slow ease-out group-hover:scale-105"
              style={`background-image:${tints[i % tints.length]};`}
              aria-hidden="true"
            />
            <img
              src={withBase(src)}
              alt={`${name} — ${i + 1}`}
              loading="lazy"
              decoding="async"
              onerror="this.remove()"
              onload="this.classList.add('is-loaded')"
              class="absolute inset-0 h-full w-full object-cover opacity-0 transition-[opacity,transform] duration-slow ease-out group-hover:scale-105 [&.is-loaded]:opacity-100"
            />
            <span class="absolute right-3 top-3 z-10 font-mono text-overline text-sand-100/80">
              {String(i + 1).padStart(2, '0')}
            </span>
          </button>
        </li>
      ))
    }
  </ul>
</section>

{/* Lightbox dialog */}
<div
  class="lightbox fixed inset-0 z-[60] hidden items-center justify-center bg-ink-900/95 p-gutter backdrop-blur-sm"
  data-lightbox
  role="dialog"
  aria-modal="true"
  aria-label={t('yachtsCommon.galleryTitle')}
>
  <button
    type="button"
    class="lb-close absolute right-5 top-5 flex h-11 w-11 items-center justify-center rounded-pill border border-line text-sand-100 transition-colors hover:border-lagoon-400 hover:text-lagoon-400"
    data-lb-close
    aria-label={t('nav.menuClose')}
  >
    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75">
      <line x1="6" y1="6" x2="18" y2="18"></line>
      <line x1="18" y1="6" x2="6" y2="18"></line>
    </svg>
  </button>

  <button
    type="button"
    class="lb-nav absolute left-4 top-1/2 -translate-y-1/2 text-sand-100 hover:text-lagoon-400"
    data-lb-prev
    aria-label={t('yachtsCommon.galleryPrev')}
  >
    <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="15 6 9 12 15 18"></polyline>
    </svg>
  </button>

  <figure class="relative flex max-h-[80svh] max-w-[1100px] items-center justify-center">
    <img
      data-lb-image
      alt=""
      class="max-h-[80svh] w-auto rounded-md object-contain"
      style="background-image: linear-gradient(135deg,#102e36,#06141a);"
    />
  </figure>

  <button
    type="button"
    class="lb-nav absolute right-4 top-1/2 -translate-y-1/2 text-sand-100 hover:text-lagoon-400"
    data-lb-next
    aria-label={t('yachtsCommon.galleryNext')}
  >
    <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="9 6 15 12 9 18"></polyline>
    </svg>
  </button>

  <span class="absolute bottom-6 left-1/2 -translate-x-1/2 font-mono text-overline text-slate-500" data-lb-counter></span>
</div>

<style>
  [data-lightbox].is-open {
    display: flex;
  }
</style>

<script>
  const gallery = document.querySelector<HTMLElement>('[data-gallery]');
  const lightbox = document.querySelector<HTMLElement>('[data-lightbox]');
  if (gallery && lightbox) {
    const items = Array.from(
      gallery.querySelectorAll<HTMLButtonElement>('[data-gallery-item]')
    );
    const srcs = items.map((b) => b.getAttribute('data-src') || '');
    const name = gallery.getAttribute('data-gallery-name') || '';
    const img = lightbox.querySelector<HTMLImageElement>('[data-lb-image]');
    const counter = lightbox.querySelector<HTMLElement>('[data-lb-counter]');
    const closeBtn = lightbox.querySelector<HTMLButtonElement>('[data-lb-close]');
    const prevBtn = lightbox.querySelector<HTMLButtonElement>('[data-lb-prev]');
    const nextBtn = lightbox.querySelector<HTMLButtonElement>('[data-lb-next]');

    let current = 0;
    let opener: HTMLElement | null = null;
    let firedOpen = false;

    const render = () => {
      if (img) {
        img.src = srcs[current];
        img.alt = `${name} — ${current + 1}`;
      }
      if (counter) counter.textContent = `${current + 1} / ${srcs.length}`;
    };

    const open = (index: number, trigger: HTMLElement) => {
      current = index;
      opener = trigger;
      render();
      lightbox.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
      if (!firedOpen) {
        firedOpen = true;
        (window as any).yachtsAnalytics?.track?.('gallery_open', { yacht_name: name });
      }
    };

    const close = () => {
      lightbox.classList.remove('is-open');
      document.body.style.overflow = '';
      opener?.focus();
    };

    const go = (delta: number) => {
      current = (current + delta + srcs.length) % srcs.length;
      render();
    };

    items.forEach((btn, i) => btn.addEventListener('click', () => open(i, btn)));
    closeBtn?.addEventListener('click', close);
    prevBtn?.addEventListener('click', () => go(-1));
    nextBtn?.addEventListener('click', () => go(1));
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') go(-1);
      else if (e.key === 'ArrowRight') go(1);
      else if (e.key === 'Tab') {
        // Simple focus trap across the 3 controls.
        const focusables = [closeBtn, prevBtn, nextBtn].filter(Boolean) as HTMLElement[];
        const idx = focusables.indexOf(document.activeElement as HTMLElement);
        e.preventDefault();
        const next = e.shiftKey ? idx - 1 : idx + 1;
        focusables[(next + focusables.length) % focusables.length]?.focus();
      }
    });
  }
</script>
