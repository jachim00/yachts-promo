---
// =========================================================================
// Craft.astro — "Built to last" chapter (LIGHT theme), id="craft".
// Repurposed from "Craftsmanship" to MATERIAL / DURABILITY: drop-stitch core,
// double-layer PVC, UV/water-resistant upholstery, corrosion-resistant
// fittings, puncture resistance, CE. Two columns: the points list + a stack of
// material detail image slots (craft/material-macro, valve-pump, deck-detail).
//
// The 2-column split is a SCOPED <style> grid with `minmax(0,…)` (not a
// Tailwind `lg:grid-cols-*`) for the same code-split reason as ContactSection.
// craft.points is an array → read via getEntry and render each line.
// =========================================================================
import { getLocaleFromUrl, useTranslations, getEntry, withBase } from '../i18n/utils';
import SectionHeader from './SectionHeader.astro';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const points = (getEntry<string[]>(lang, 'craft.points') ?? []).filter(Boolean);

// Material detail image slots (1:1 / 1:1 / 3:2). Missing files → gradient art.
const shots = [
  { img: 'media/craft/material-macro.jpg', alt: 'media.alt.materialMacro', ratio: 'aspect-square' },
  { img: 'media/craft/valve-pump.jpg', alt: 'media.alt.valvePump', ratio: 'aspect-square' },
  { img: 'media/craft/deck-detail.jpg', alt: 'media.alt.deckDetail', ratio: 'aspect-[3/2]' },
] as const;

const tints = [
  'linear-gradient(135deg, #faf6ee, #efe7d6)',
  'linear-gradient(135deg, #ffffff, #f5efe3)',
  'linear-gradient(135deg, #efe7d6, #faf6ee)',
];
---

<section id="craft" class="section scroll-mt-24 bg-ink-800">
  <div class="shell shell-wide">
    <SectionHeader overline={t('craft.overline')} title={t('craft.title')} as="h2" />

    <div class="craft-grid mt-12">
      {/* Left: the durability points. */}
      <ul class="craft-points flex flex-col gap-5" data-reveal data-reveal-stagger>
        {
          points.map((point) => (
            <li class="flex items-start gap-4 border-t border-line pt-5" data-reveal-item>
              <span
                class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-pill text-coral-600"
                aria-hidden="true"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              <p class="text-body-l text-sand-200">{point}</p>
            </li>
          ))
        }
      </ul>

      {/* Right: a stack of material detail image slots. */}
      <div class="craft-media flex flex-col gap-5" data-reveal data-reveal-delay="0.1">
        {
          shots.map((shot, i) => (
            <div
              class={`relative overflow-hidden rounded-lg border border-line bg-ink-700 shadow-soft ${shot.ratio}`}
            >
              <div
                class="absolute inset-0"
                style={`background-image:${tints[i % tints.length]};`}
                aria-hidden="true"
              />
              <img
                src={withBase(shot.img)}
                alt={t(shot.alt)}
                loading="lazy"
                decoding="async"
                onerror="this.remove()"
                onload="this.classList.add('is-loaded')"
                class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-slow ease-out [&.is-loaded]:opacity-100"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* 7/5 split at lg, stacked below — scoped grid (code-split safe). */
  .craft-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-7);
  }
  @media (min-width: 1024px) {
    .craft-grid {
      grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
      gap: var(--space-8);
      align-items: start;
    }
  }
  .craft-grid > * {
    min-width: 0;
  }
</style>
