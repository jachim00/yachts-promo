---
// =========================================================================
// Craft.astro — LIGHT "intermission" chapter (sand background, ink text).
// Breaks the dark cinematic rhythm. Lists craft.points[] (4 items from i18n,
// read via getEntry as an array, with a t()-resilient fallback).
// =========================================================================
import { getLocaleFromUrl, useTranslations, getEntry } from '../i18n/utils';
import SectionHeader from './SectionHeader.astro';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

// craft.points is an array of strings in i18n.
const points = (getEntry<string[]>(lang, 'craft.points') ?? []).filter(
  (p) => typeof p === 'string'
);
---

<section id="craft" class="section scroll-mt-24 bg-sand-100 text-ink-900">
  <div class="shell shell-wide grid gap-10 lg:grid-cols-12 lg:items-start">
    <div class="lg:col-span-5">
      <SectionHeader
        overline={t('craft.overline')}
        title={t('craft.title')}
        as="h2"
        tone="light"
      />
      {/* Placeholder craft visual: layered ink panel (no hotlinked media). */}
      <div
        class="mt-8 hidden aspect-[4/3] w-full overflow-hidden rounded-lg lg:block"
        style="background-image: linear-gradient(135deg, #102e36, #18424c 60%, #0b2128); box-shadow: var(--shadow-soft);"
        role="img"
        aria-label="Craft detail placeholder"
      >
        <span class="sr-only">Placeholder — replace with /public/media/craft-detail.jpg</span>
      </div>
    </div>

    <ul class="grid gap-6 sm:grid-cols-2 lg:col-span-7" data-reveal data-reveal-stagger>
      {
        points.map((point, i) => (
          <li
            class="flex flex-col gap-4 rounded-md border border-ink-900/10 bg-sand-200/40 p-6"
            data-reveal-item
          >
            <span class="font-mono text-overline uppercase tracking-overline text-coral-600">
              {String(i + 1).padStart(2, '0')}
            </span>
            <p class="text-body text-ink-700">{point}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
