---
// =========================================================================
// HowItWorks.astro — "How it works" chapter (LIGHT theme), id="how-it-works".
// Three product steps — Inflate · Cast off · Pack away — each with a number,
// heading, short copy and an image slot (how/step-*.jpg). Uses the Reveal
// stagger hook (no heavy pinning) and respects prefers-reduced-motion.
//
// IMPORTANT: the 3-up grid is a SCOPED <style> with
// `grid-template-columns: minmax(0, …)` rather than a Tailwind `lg:grid-cols-3`
// utility — Astro's per-page CSS code-split has been observed to drop those
// utilities on this site (see ContactSection.astro / fleet[slug] scoped grids),
// so the layout must not depend on them.
// =========================================================================
import { getLocaleFromUrl, useTranslations, withBase } from '../i18n/utils';
import SectionHeader from './SectionHeader.astro';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

// Step keys are fixed by the i18n contract (how.steps.*). Each carries a media
// slot + alt; missing files fall back to the gradient placeholder.
const steps = [
  { key: 'inflate', img: 'media/how/step-inflate.jpg', alt: 'media.alt.stepInflate' },
  { key: 'castoff', img: 'media/how/step-castoff.jpg', alt: 'media.alt.stepCastoff' },
  { key: 'pack', img: 'media/how/step-pack.jpg', alt: 'media.alt.stepPack' },
] as const;

// Light beige/cream placeholder tints (shown until a real image loads).
const tints = [
  'linear-gradient(140deg, #faf6ee, #efe7d6 55%, #f5efe3)',
  'linear-gradient(140deg, #ffffff, #f5efe3 50%, #efe7d6)',
  'linear-gradient(140deg, #f5efe3, #faf6ee 60%, #efe7d6)',
];
---

<section id="how-it-works" class="section scroll-mt-24 bg-ink-900">
  <div class="shell shell-wide">
    <SectionHeader overline={t('how.overline')} title={t('how.title')} as="h2" />

    <ol class="how-grid mt-12" data-reveal data-reveal-stagger>
      {
        steps.map((step, i) => (
          <li class="how-step flex flex-col" data-reveal-item>
            {/* Media slot — gradient placeholder + optional real image (3:2). */}
            <div class="relative mb-6 aspect-[3/2] overflow-hidden rounded-lg border border-line bg-ink-700 shadow-soft">
              <div
                class="absolute inset-0"
                style={`background-image:${tints[i % tints.length]};`}
                aria-hidden="true"
              />
              <img
                src={withBase(step.img)}
                alt={t(step.alt)}
                loading="lazy"
                decoding="async"
                onerror="this.remove()"
                onload="this.classList.add('is-loaded')"
                class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-slow ease-out [&.is-loaded]:opacity-100"
              />
              <span
                class="absolute left-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-pill bg-ink-700 font-mono text-overline text-coral-600 shadow-soft"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>

            <h3 class="font-display text-h3 text-sand-100">
              {t(`how.steps.${step.key}.title`)}
            </h3>
            <p class="mt-3 text-body text-sand-300">
              {t(`how.steps.${step.key}.body`)}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  /* 3-up at lg, 1-up below — scoped so the per-page CSS split can't drop it.
     minmax(0,…) keeps the tracks shrinkable (no horizontal blowout). */
  .how-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-7);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 768px) {
    .how-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-6);
    }
  }
  .how-grid > * {
    min-width: 0;
  }
</style>
