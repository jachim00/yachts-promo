---
// =========================================================================
// Nav.astro — sticky navigation.
//  - transparent over the hero, turns solid (--ink-900 + hairline) after scroll
//  - desktop inline menu + LanguageSwitcher + primary CTA
//  - mobile: full-screen overlay menu (accessible, focus-trapped, esc to close)
//  - sticky chapter indicator (right-edge dots) reflecting the active section
// Menu items anchor to in-page chapters on the home page; on sub-pages they
// link back to the localized home + hash.
// All labels via t(); all links via localizedPath()/withBase().
// =========================================================================
import { getLocaleFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import Button from './Button.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  /** When false, menu items point to /<lang>#chapter instead of #chapter. */
  onHome?: boolean;
}

const { onHome = true } = Astro.props;
const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const homeHref = localizedPath(lang, '');

// Chapter anchors used both for the menu and for the side indicator.
const chapters = [
  { id: 'manifesto', label: t('nav.manifesto') },
  { id: 'fleet', label: t('nav.fleet') },
  { id: 'experiences', label: t('nav.experiences') },
  { id: 'craft', label: t('nav.craft') },
  { id: 'contact', label: t('nav.contact') },
];

const hrefFor = (id: string) => (onHome ? `#${id}` : `${homeHref}#${id}`);
---

<header
  id="site-nav"
  data-nav
  class="fixed inset-x-0 top-0 z-50 transition-colors duration-base ease-out"
>
  <div class="shell shell-wide flex items-center justify-between gap-6 py-4">
    {/* Brand / home link */}
    <a
      href={homeHref}
      class="nav-brand font-display text-h3 leading-none text-sand-100 transition-opacity duration-fast hover:opacity-80"
      aria-label="MARÉ — home"
    >
      MAR<span class="text-coral-500">É</span>
    </a>

    {/* Desktop menu */}
    <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary">
      {
        chapters.map((c) => (
          <a
            href={hrefFor(c.id)}
            data-nav-link={c.id}
            class="nav-link relative text-small font-medium text-sand-300 transition-colors duration-fast ease-out hover:text-sand-100"
          >
            {c.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-5 lg:flex">
      <LanguageSwitcher variant="inline" />
      <Button variant="primary" href={hrefFor('contact')} ctaLocation="nav">
        {t('nav.cta')}
      </Button>
    </div>

    {/* Mobile menu trigger */}
    <button
      type="button"
      class="nav-burger relative z-50 flex h-11 w-11 items-center justify-center rounded-pill text-sand-100 lg:hidden"
      data-menu-open
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label={t('nav.menuOpen')}
    >
      <span class="burger-box" aria-hidden="true">
        <span class="burger-line"></span>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </span>
    </button>
  </div>

  {/* Right-edge chapter indicator (desktop, home only) */}
  {
    onHome && (
      <ul
        class="chapter-dots pointer-events-none fixed right-6 top-1/2 z-40 hidden -translate-y-1/2 flex-col gap-4 xl:flex"
        aria-hidden="true"
      >
        {chapters.map((c) => (
          <li>
            <a
              href={`#${c.id}`}
              data-chapter-dot={c.id}
              class="pointer-events-auto block h-2.5 w-2.5 rounded-pill border border-sand-300/50 transition-all duration-base ease-out"
              tabindex="-1"
            >
              <span class="sr-only">{c.label}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</header>

{/* Mobile full-screen overlay menu */}
<div
  id="mobile-menu"
  data-mobile-menu
  class="fixed inset-0 z-40 flex translate-y-[-100%] flex-col bg-ink-900 px-gutter pb-9 pt-10 opacity-0 transition-[transform,opacity] duration-slow ease-out lg:hidden"
  hidden
>
  <nav class="mt-16 flex flex-1 flex-col justify-center gap-6" aria-label="Mobile">
    {
      chapters.map((c, i) => (
        <a
          href={hrefFor(c.id)}
          data-mobile-link
          style={`--i:${i}`}
          class="mobile-link font-display text-h2 text-sand-100 transition-colors duration-fast hover:text-lagoon-400"
        >
          {c.label}
        </a>
      ))
    }
  </nav>

  <div class="flex flex-col gap-6 border-t border-line pt-6">
    <LanguageSwitcher variant="menu" />
    <Button variant="primary" href={hrefFor('contact')} ctaLocation="nav-mobile" class="w-full">
      {t('nav.cta')}
    </Button>
  </div>
</div>

<style>
  /* Solid state toggled by JS when scrolled past the hero threshold. */
  [data-nav].is-solid {
    background: var(--ink-900);
    border-bottom: 1px solid var(--line);
  }

  /* Burger icon */
  .burger-box {
    position: relative;
    display: block;
    width: 24px;
    height: 16px;
  }
  .burger-line {
    position: absolute;
    left: 0;
    height: 2px;
    width: 100%;
    border-radius: 2px;
    background: currentColor;
    transition:
      transform var(--dur-base) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out),
      top var(--dur-base) var(--ease-out);
  }
  .burger-line:nth-child(1) {
    top: 0;
  }
  .burger-line:nth-child(2) {
    top: 7px;
  }
  .burger-line:nth-child(3) {
    top: 14px;
  }
  :global([data-menu-open][aria-expanded='true']) .burger-line:nth-child(1) {
    top: 7px;
    transform: rotate(45deg);
  }
  :global([data-menu-open][aria-expanded='true']) .burger-line:nth-child(2) {
    opacity: 0;
  }
  :global([data-menu-open][aria-expanded='true']) .burger-line:nth-child(3) {
    top: 7px;
    transform: rotate(-45deg);
  }

  /* Mobile menu open state */
  [data-mobile-menu].is-open {
    transform: translateY(0);
    opacity: 1;
  }
  .mobile-link {
    opacity: 0;
    transform: translateY(14px);
  }
  [data-mobile-menu].is-open .mobile-link {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
    transition-delay: calc(120ms + var(--i) * 60ms);
  }

  /* Active chapter dot */
  :global([data-chapter-dot].is-active) {
    background: var(--coral-500);
    border-color: var(--coral-500);
    transform: scale(1.3);
  }
  /* Active desktop nav link underline */
  .nav-link.is-active {
    color: var(--sand-100);
  }
  .nav-link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    height: 2px;
    width: 100%;
    background: var(--lagoon-400);
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-link,
    [data-mobile-menu] {
      transition-duration: 0.001ms !important;
    }
  }
</style>

<script>
  // ---- Nav behaviour island ------------------------------------------------
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  const openBtn = document.querySelector<HTMLButtonElement>('[data-menu-open]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const mobileLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('[data-mobile-link]')
  );

  // Solid-after-scroll. Threshold ~ 80% viewport (past hero).
  const onScroll = () => {
    if (!nav) return;
    const solid = window.scrollY > Math.min(window.innerHeight * 0.7, 600);
    nav.classList.toggle('is-solid', solid);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // ---- Mobile menu open/close + simple focus management --------------------
  let lastFocused: HTMLElement | null = null;

  const setOpen = (open: boolean) => {
    if (!menu || !openBtn) return;
    if (open) {
      lastFocused = document.activeElement as HTMLElement;
      menu.hidden = false;
      // next frame so the transition runs
      requestAnimationFrame(() => menu.classList.add('is-open'));
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      mobileLinks[0]?.focus();
    } else {
      menu.classList.remove('is-open');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      // hide after transition to remove from tab order
      window.setTimeout(() => {
        if (!menu.classList.contains('is-open')) menu.hidden = true;
      }, 500);
      lastFocused?.focus();
    }
  };

  openBtn?.addEventListener('click', () => {
    const isOpen = openBtn.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  // Close on link click + on Escape
  mobileLinks.forEach((l) => l.addEventListener('click', () => setOpen(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && openBtn?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
    }
  });

  // ---- Chapter indicator + active nav link (IntersectionObserver) ----------
  const dots = Array.from(document.querySelectorAll<HTMLElement>('[data-chapter-dot]'));
  const links = Array.from(document.querySelectorAll<HTMLElement>('[data-nav-link]'));
  const sections = ['manifesto', 'fleet', 'experiences', 'craft', 'contact']
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => !!el);

  if (sections.length) {
    const setActive = (id: string) => {
      dots.forEach((d) =>
        d.classList.toggle('is-active', d.getAttribute('data-chapter-dot') === id)
      );
      links.forEach((l) =>
        l.classList.toggle('is-active', l.getAttribute('data-nav-link') === id)
      );
    };
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible?.target.id) setActive(visible.target.id);
      },
      { rootMargin: '-45% 0px -45% 0px', threshold: [0, 0.25, 0.5, 1] }
    );
    sections.forEach((s) => io.observe(s));
  }
</script>
