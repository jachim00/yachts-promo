---
// =========================================================================
// Testimonials.astro — "Voices" chapter (dark).
// Renders testimonials.items[] (3 owner stories) from i18n via getEntry.
// Static editorial cards (no JS dependency); revealed on scroll.
// =========================================================================
import { getLocaleFromUrl, useTranslations, getEntry } from '../i18n/utils';
import SectionHeader from './SectionHeader.astro';

interface Testimonial {
  quote: string;
  author: string;
  role: string;
}

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const items = (getEntry<Testimonial[]>(lang, 'testimonials.items') ?? []).filter(
  (it) => it && typeof it.quote === 'string'
);

// Hide obvious [[PLACEHOLDER]] attribution while keeping the quote.
const clean = (v: string) => (v && !v.startsWith('[[') ? v : '');
---

<section id="voices" class="section scroll-mt-24 bg-ink-900">
  <div class="shell shell-wide">
    <SectionHeader overline={t('testimonials.overline')} title={t('testimonials.title')} as="h2" />

    <div class="mt-10 grid gap-6 md:grid-cols-3" data-reveal data-reveal-stagger>
      {
        items.map((item) => (
          <figure
            class="flex flex-col gap-6 rounded-lg border border-line bg-ink-700 p-7"
            data-reveal-item
          >
            <svg
              class="h-7 w-7 text-coral-500"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M9.5 7C6.5 7 4 9.5 4 12.8 4 15.6 6 17 8 17c.3 0 .6 0 .8-.1-.5 1.4-1.7 2.4-3.3 2.9l.7 1.7c3.3-1 5.5-3.7 5.5-7.6V9.2C11.7 7.9 10.7 7 9.5 7Zm8.8 0c-3 0-5.5 2.5-5.5 5.8 0 2.8 2 4.2 4 4.2.3 0 .6 0 .8-.1-.5 1.4-1.7 2.4-3.3 2.9l.7 1.7c3.3-1 5.5-3.7 5.5-7.6V9.2C20.5 7.9 19.5 7 18.3 7Z" />
            </svg>
            <blockquote class="text-body-l text-sand-100">{item.quote}</blockquote>
            {(clean(item.author) || clean(item.role)) && (
              <figcaption class="mt-auto flex flex-col gap-0.5 border-t border-line pt-5">
                {clean(item.author) && (
                  <span class="text-small font-semibold text-sand-100">{item.author}</span>
                )}
                {clean(item.role) && (
                  <span class="text-small text-slate-500">{item.role}</span>
                )}
              </figcaption>
            )}
          </figure>
        ))
      }
    </div>
  </div>
</section>
