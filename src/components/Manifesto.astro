---
// =========================================================================
// Manifesto.astro — editorial philosophy chapter (dark).
// Large display statement with generous whitespace; the lead sits in a
// measured column. Reveal hooks for animations.ts.
// =========================================================================
import { getLocaleFromUrl, useTranslations } from '../i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="manifesto" class="section scroll-mt-24 bg-ink-900">
  <div class="shell shell-wide grid items-end gap-9 lg:grid-cols-12">
    <div class="lg:col-span-7" data-reveal data-reveal-stagger>
      <p class="overline mb-6" data-reveal-item>{t('manifesto.overline')}</p>
      <h2 class="font-display text-h1 text-sand-100" data-reveal-item>
        {t('manifesto.title')}
      </h2>
    </div>
    <div class="lg:col-span-5" data-reveal data-reveal-delay="0.15">
      <p class="prose-measure text-body-l text-sand-300">{t('manifesto.lead')}</p>
      {/* Thin accent rule for editorial rhythm */}
      <span class="mt-7 block h-px w-24 bg-grad-accent" aria-hidden="true"></span>
    </div>
  </div>
</section>
