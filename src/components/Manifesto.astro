---
// =========================================================================
// Manifesto.astro — "Our philosophy" chapter (LIGHT theme).
// Editorial statement: no marina, no trailer — freedom you can carry.
// A soft atmosphere image sits behind the copy as an elegant gradient
// placeholder until the real file (media/hero/atmosphere-dawn.jpg) is added.
// Tokens used exactly like the other light components (bg-ink-*, text-sand-*).
// =========================================================================
import { getLocaleFromUrl, useTranslations, withBase } from '../i18n/utils';
import SectionHeader from './SectionHeader.astro';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const atmosphere = withBase('media/hero/atmosphere-dawn.jpg');
const atmosphereAlt = t('media.alt.atmosphereDawn');
---

<section id="manifesto" class="section relative scroll-mt-24 overflow-hidden bg-ink-800">
  {/* Atmosphere background — gradient placeholder + optional real image. */}
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(120% 90% at 80% 10%, rgba(232,85,47,0.05), transparent 55%), radial-gradient(120% 90% at 12% 95%, rgba(11,33,40,0.05), transparent 55%), linear-gradient(180deg,#faf6ee,#f5efe3 80%);"
    >
    </div>
    <img
      src={atmosphere}
      alt=""
      loading="lazy"
      decoding="async"
      onerror="this.remove()"
      onload="this.classList.add('is-loaded')"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-cine [&.is-loaded]:opacity-25"
    />
    {/* Soft wash so the copy stays legible over any photo. */}
    <div
      class="absolute inset-0"
      style="background: linear-gradient(180deg, rgba(250,246,238,0.72), rgba(245,239,227,0.86));"
    >
    </div>
  </div>

  {/* sr-only dev marker for the media slot. */}
  <span class="sr-only">{atmosphereAlt}</span>

  <div class="shell shell-wide relative z-10">
    <SectionHeader
      overline={t('manifesto.overline')}
      title={t('manifesto.title')}
      lead={t('manifesto.lead')}
      as="h2"
    />
  </div>
</section>
