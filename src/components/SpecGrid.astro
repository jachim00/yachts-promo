---
// =========================================================================
// SpecGrid.astro — yacht specification grid of animated figures.
// Data-driven from a YachtSpec (yachts.ts). Labels via yachtsCommon.*.
// Only renders fields that are present (optional fields are skipped).
// Wraps SpecCounter for each figure.
//
// For the inflatable-platform product the grid surfaces the CONCISE figures
// (dimensions / capacity / weight / pressure / inflation time). The long
// descriptive fields (material / drive / included) are shown in the Tabs
// component below, not as oversized counters here.
// =========================================================================
import { getLocaleFromUrl, useTranslations } from '../i18n/utils';
import type { YachtSpec } from '../data/yachts';
import SpecCounter from './SpecCounter.astro';

interface Props {
  spec: YachtSpec;
}

const { spec } = Astro.props;
const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

// Concise figures only (long prose lives in Tabs: material/drive/included).
const order: Array<{ key: keyof YachtSpec; labelKey: string }> = [
  { key: 'deckLengthInflated', labelKey: 'yachtsCommon.deckLengthInflated' },
  { key: 'beamInflated', labelKey: 'yachtsCommon.beamInflated' },
  { key: 'capacity', labelKey: 'yachtsCommon.capacity' },
  { key: 'totalWeight', labelKey: 'yachtsCommon.totalWeight' },
  { key: 'packedSize', labelKey: 'yachtsCommon.packedSize' },
  { key: 'workingPressure', labelKey: 'yachtsCommon.workingPressure' },
  { key: 'inflationTime', labelKey: 'yachtsCommon.inflationTime' },
];

const rows = order
  .map(({ key, labelKey }) => ({ value: spec[key], label: t(labelKey) }))
  .filter((r): r is { value: string; label: string } => typeof r.value === 'string' && !!r.value);
---

<section class="spec-grid">
  <header class="mb-8 flex flex-col gap-3">
    <h2 class="overline">{t('yachtsCommon.specsTitle')}</h2>
  </header>

  <dl
    class="grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3 lg:grid-cols-4"
    data-reveal
    data-reveal-stagger
    data-spec-grid
  >
    {rows.map((row) => <SpecCounter label={row.label} value={row.value} />)}
  </dl>

  <p class="mt-8 font-mono text-overline uppercase tracking-overline text-slate-500">
    {t('yachtsCommon.specsNote')}
  </p>
</section>
