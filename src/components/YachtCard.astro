---
// =========================================================================
// YachtCard.astro — fleet teaser card (one "character").
//  - placeholder image (gradient art when media missing; via withBase())
//  - name + i18n tagline
//  - hover: image zoom + overlay reveal of tagline + CTA
//  - links to /<lang>/fleet/<slug> via localizedPath()
//  - dispatches view_yacht (defensive) on click
// =========================================================================
import { getLocaleFromUrl, useTranslations, localizedPath, withBase } from '../i18n/utils';
import type { Yacht } from '../data/yachts';

interface Props {
  yacht: Yacht;
  /** 0-based index, used for the staggered reveal. */
  index?: number;
}

const { yacht, index = 0 } = Astro.props;
const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const tagline = t(`yachts.${yacht.slug}.tagline`);
const href = localizedPath(lang, `fleet/${yacht.slug}`);
const img = withBase(yacht.heroPlaceholder);

// Distinct LIGHT tint per card for visual variety — warm beige/cream washes
// (placeholder art that shows through until a real <img> loads).
const tints = [
  'linear-gradient(140deg, #faf6ee, #efe7d6 55%, #f5efe3)',
  'linear-gradient(140deg, #ffffff, #f5efe3 50%, #efe7d6)',
  'linear-gradient(140deg, #f5efe3, #faf6ee 60%, #efe7d6)',
];
const tint = tints[index % tints.length];
---

<a
  href={href}
  data-view-yacht={yacht.name}
  data-reveal-item
  class="yacht-card group relative flex flex-col overflow-hidden rounded-lg border border-line bg-ink-700 shadow-soft transition-transform duration-base ease-out hover:-translate-y-1 focus-visible:-translate-y-1"
>
  {/* Media (placeholder gradient; a real <img> overlays it when it loads) */}
  <div class="relative aspect-[4/5] overflow-hidden">
    <div
      class="absolute inset-0 transition-transform duration-slow ease-out group-hover:scale-105"
      style={`background-image:${tint};`}
      aria-hidden="true"
    >
    </div>
    <img
      src={img}
      alt=""
      loading="lazy"
      decoding="async"
      onerror="this.remove()"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-[opacity,transform] duration-slow ease-out group-hover:scale-105 [&.is-loaded]:opacity-100"
      onload="this.classList.add('is-loaded')"
    />
    {/* Bottom gradient for label legibility (soft white wash on light tints) */}
    <div
      class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-white/70 to-transparent"
      aria-hidden="true"
    >
    </div>

    {/* Order index marker */}
    <span
      class="absolute left-5 top-5 font-mono text-overline uppercase tracking-overline text-slate-500"
    >
      {String(yacht.order).padStart(2, '0')}
    </span>
  </div>

  {/* Text block */}
  <div class="relative flex flex-1 flex-col gap-3 p-6">
    <h3 class="font-display text-h3 text-sand-100">{yacht.name}</h3>
    <p class="text-small text-sand-300">{tagline}</p>

    <span
      class="mt-3 inline-flex items-center gap-2 text-small font-semibold text-coral-600 transition-transform duration-base ease-out group-hover:translate-x-1"
    >
      {t('fleet.viewYacht')}
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </span>
  </div>
</a>
