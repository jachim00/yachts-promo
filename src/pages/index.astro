---
// Root redirect: "/" -> best language (Accept-Language client-side),
// falling back to /en. Because prefixDefaultLocale:true, even English lives
// under /<base>/en. This page is intentionally minimal and base-aware.
import { withBase, locales, defaultLocale } from '../i18n/utils';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const fallback = withBase(defaultLocale);
const localeList = JSON.stringify(locales);
---

<!doctype html>
<html lang={defaultLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MARÉ</title>
    {/* No-JS fallback: send crawlers/users straight to the default locale. */}
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <link rel="canonical" href={fallback} />
    <script is:inline define:vars={{ base, localeList, fallback }}>
      (function () {
        try {
          var supported = JSON.parse(localeList);
          var pref = (navigator.languages && navigator.languages[0]) || navigator.language || 'en';
          var lang = String(pref).slice(0, 2).toLowerCase();
          var target = supported.indexOf(lang) !== -1 ? base + '/' + lang : fallback;
          window.location.replace(target);
        } catch (e) {
          window.location.replace(fallback);
        }
      })();
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={fallback}>MARÉ</a>…</p>
  </body>
</html>
