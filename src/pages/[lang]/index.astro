---
// =========================================================================
// [lang]/index.astro — the cinematic one-page.
//
// Content & repositioning v2 — the product is now a PREMIUM INFLATABLE,
// PORTABLE drop-stitch yacht/platform. The "Experiences" horizontal-scroll
// chapter was removed; a product "How it works" chapter was added; the
// Manifesto chapter was restored; Craft (Material) and Testimonials chapters
// were later removed at the owner's request.
//
// Chapter flow:
//   Hero → Manifesto → FleetTeaser → HowItWorks → Contact
//
// Wrapped in BaseLayout; <Seo slot="head"/> + <CookieConsent/> are Systems
// components consumed as-is. Nav/Footer are Builder Frontend's own.
// getStaticPaths returns all 5 locales.
// =========================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import Seo from '../../components/Seo.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import Manifesto from '../../components/Manifesto.astro';
import FleetTeaser from '../../components/FleetTeaser.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import ContactSection from '../../components/ContactSection.astro';
import { locales, useTranslations, getLocaleFromUrl } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = getLocaleFromUrl(Astro.url) as Locale;
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('meta.home.title')} description={t('meta.home.description')}>
  <Seo
    slot="head"
    lang={lang}
    title={t('meta.home.title')}
    description={t('meta.home.description')}
    canonicalPath=""
  />

  <Nav onHome={true} />

  <main id="main">
    <Hero />
    <Manifesto />
    <FleetTeaser />
    <HowItWorks />
    <ContactSection />
  </main>

  <Footer />

  {/* Motion island — loaded only here (hero/reveals/counters). */}
  <script>
    import '../../scripts/animations.ts';
  </script>
</BaseLayout>
