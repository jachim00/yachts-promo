---
// =========================================================================
// /[lang]/cookies — Cookie Policy. Builder Systems.
// Localized for all 5 locales via getStaticPaths. Copy comes from i18n
// legal.cookies.*, with [[PLACEHOLDER]] fields (company, cookie lists) to be
// filled before launch. Mounts <Seo slot="head" /> and exposes a "Cookie
// settings" trigger that opens the CookieConsent modal.
// =========================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import Seo from '../../components/Seo.astro';
import { locales, useTranslations, getLocaleFromUrl, localizedPath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = getLocaleFromUrl(Astro.url) as Locale;
const t = useTranslations(lang);

const categories = [
  { title: t('legal.cookies.necessaryTitle'), body: t('legal.cookies.necessaryBody') },
  { title: t('legal.cookies.analyticsTitle'), body: t('legal.cookies.analyticsBody') },
  { title: t('legal.cookies.marketingTitle'), body: t('legal.cookies.marketingBody') },
];
---

<BaseLayout lang={lang} title={t('meta.cookies.title')} description={t('meta.cookies.description')}>
  <Seo
    slot="head"
    lang={lang}
    title={t('meta.cookies.title')}
    description={t('meta.cookies.description')}
    canonicalPath="cookies"
  />

  <main id="main" class="legal section">
    <div class="shell">
      <a class="legal__back" href={localizedPath(lang, '')}>{t('yachtsCommon.backToFleet')}</a>

      <header class="legal__header">
        <p class="overline">{t('footer.legal')}</p>
        <h1 class="legal__title">{t('legal.cookies.title')}</h1>
        <p class="legal__updated">{t('legal.cookies.lastUpdated')}</p>
      </header>

      <p class="legal__intro prose-measure">{t('legal.cookies.intro')}</p>

      <section class="legal__section">
        <h2 class="legal__h2">{t('legal.cookies.whatTitle')}</h2>
        <p class="legal__body prose-measure">{t('legal.cookies.whatBody')}</p>
      </section>

      <section class="legal__section">
        <h2 class="legal__h2">{t('legal.cookies.categoriesTitle')}</h2>
        {
          categories.map((c) => (
            <div class="legal__cat">
              <h3 class="legal__h3">{c.title}</h3>
              <p class="legal__body prose-measure">{c.body}</p>
            </div>
          ))
        }
      </section>

      <section class="legal__section">
        <h2 class="legal__h2">{t('legal.cookies.manageTitle')}</h2>
        <p class="legal__body prose-measure">{t('legal.cookies.manageBody')}</p>
        <p>
          <button type="button" class="legal__cookie-btn" data-cc="settings">
            {t('footer.cookieSettings')}
          </button>
        </p>
      </section>

      <p class="legal__cookie-link">
        <a href={localizedPath(lang, 'privacy')}>{t('legal.privacy.title')}</a>
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .legal {
    color: var(--sand-100);
  }
  .legal__back {
    display: inline-block;
    margin-bottom: var(--space-7);
    font-family: var(--font-mono);
    font-size: var(--fs-overline);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--lagoon-400);
    text-decoration: none;
  }
  .legal__back:hover {
    text-decoration: underline;
  }
  .legal__header {
    margin-bottom: var(--space-7);
  }
  .legal__title {
    margin: var(--space-2) 0 var(--space-3);
    font-size: var(--fs-h1);
    color: var(--sand-100);
  }
  .legal__updated {
    margin: 0;
    font-size: var(--fs-small);
    color: var(--slate-500);
  }
  .legal__intro {
    font-size: var(--fs-body-l);
    color: var(--sand-200);
    margin-bottom: var(--space-8);
  }
  .legal__section {
    margin-bottom: var(--space-7);
  }
  .legal__h2 {
    font-size: var(--fs-h3);
    color: var(--sand-100);
    margin: 0 0 var(--space-3);
  }
  .legal__h3 {
    font-size: var(--fs-body-l);
    color: var(--sand-100);
    margin: var(--space-5) 0 var(--space-2);
  }
  .legal__cat {
    padding-left: var(--space-4);
    border-left: 2px solid var(--line);
    margin-bottom: var(--space-4);
  }
  .legal__body {
    color: var(--sand-300);
    margin: 0;
  }
  .legal__cookie-link {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--line);
    font-size: var(--fs-small);
    color: var(--sand-300);
  }
  .legal__cookie-btn {
    background: none;
    border: 0;
    padding: 0;
    font: inherit;
    color: var(--lagoon-400);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .legal__cookie-btn:hover {
    color: var(--lagoon-500);
  }
</style>
